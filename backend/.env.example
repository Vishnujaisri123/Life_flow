# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/lifeflow?retryWrites=true&w=majority

# JWT signing secret (use a long random string in production)
JWT_SECRET=change_me_to_a_secure_random_string

# Server
PORT=5000
NODE_ENV=development

# Comma-separated allowed origins (Vite dev + production frontend URL)
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# OpenRouter (https://openrouter.ai) — server-side only, never expose in frontend
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional metadata for OpenRouter dashboard
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=LifeFlow AI

# Firebase Cloud Messaging (optional — server push when credentials set)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste private key with \n for newlines, or use literal newlines in .env
FIREBASE_PRIVATE_KEY=
