# LifeFlow frontend — copy to .env.local for local dev
# When unset, pages use placeholder data (demo mode).

# Express API base URL (include /api suffix)
VITE_API_URL=http://localhost:5000/api

# JWT is stored in sessionStorage (see src/services/authStorage.ts).
# httpOnly cookies require a same-origin BFF; this SPA uses Bearer tokens.

# OpenRouter API key lives on the backend only (OPENROUTER_API_KEY in backend/.env).
# When VITE_API_URL is unset, the AI assistant uses demo canned responses.

# Firebase Cloud Messaging (optional — browser push when all vars set)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
